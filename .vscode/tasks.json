{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "compile",
			"type": "shell",
			"command": "$env:Path = [System.Environment]::GetEnvironmentVariable('Path','Machine') + ';' + [System.Environment]::GetEnvironmentVariable('Path','User'); npm run compile",
			"options": {
				"shell": {
					"executable": "C:\\Windows\\System32\\WindowsPowerShell\\v1.0\\powershell.exe",
					"args": [
						"-NonInteractive",
						"-Command"
					]
				}
			},
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"presentation": {
				"reveal": "always"
			},
			"problemMatcher": [
				"$ts-webpack-watch"
			]
		},
		{
			"label": "watch",
			"type": "shell",
			"command": "$env:Path = [System.Environment]::GetEnvironmentVariable('Path','Machine') + ';' + [System.Environment]::GetEnvironmentVariable('Path','User'); npm run watch",
			"options": {
				"shell": {
					"executable": "C:\\Windows\\System32\\WindowsPowerShell\\v1.0\\powershell.exe",
					"args": [
						"-NonInteractive",
						"-Command"
					]
				}
			},
			"group": "build",
			"isBackground": true,
			"presentation": {
				"reveal": "never"
			},
			"problemMatcher": [
				"$ts-webpack-watch"
			]
		},
		{
			"label": "compile-check",
			"type": "shell",
			"command": "npm run compile",
			"problemMatcher": [
				"$tsc"
			],
			"group": "build"
		},
		{
			"label": "npm-compile",
			"type": "shell",
			"command": "npm run compile",
			"problemMatcher": [
				"$tsc"
			],
			"group": "build"
		},
		{
			"label": "npm-compile2",
			"type": "shell",
			"command": "$env:Path = [System.Environment]::GetEnvironmentVariable('Path','Machine') + ';' + [System.Environment]::GetEnvironmentVariable('Path','User'); npm run compile",
			"problemMatcher": [
				"$tsc"
			],
			"group": "build"
		}
	]
}